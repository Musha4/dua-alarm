# ============================================================
# Supabase configuration
# ============================================================
# WHERE TO FIND THESE VALUES:
#   1. Open your project at https://supabase.com/dashboard
#   2. Go to: Project Settings (gear icon) → API Keys / Data API
#   3. Copy:
#      - "Project URL"        → NEXT_PUBLIC_SUPABASE_URL
#      - "anon / public" key  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# THEN:
#   1. Copy this file to `.env.local` (same folder):
#        cp .env.local.example .env.local
#   2. Paste your real values below.
#   3. Restart the dev server (`npm run dev`).
#
# The anon key is safe to expose in the browser — it can only do what
# your Row Level Security policies allow (see supabase/schema.sql:
# insert-only, no reading the list).
#
# FOR VERCEL: add these same two variables under
#   Project → Settings → Environment Variables, then redeploy.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# Google Analytics (optional)
# ============================================================
# ADD YOUR TRACKING ID HERE to turn on Google Analytics:
#   1. Create a GA4 property at https://analytics.google.com
#      (Admin → Create → Property, then add a "Web" data stream)
#   2. Copy the stream's Measurement ID — it looks like G-XXXXXXXXXX
#   3. Uncomment the line below and paste it in
#   4. Restart the dev server / redeploy
# Leave it commented out and no GA code is shipped at all.
# (Vercel Analytics needs no ID — it activates automatically when
#  deployed on Vercel with Analytics enabled in the dashboard.)

# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
